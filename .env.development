# =============================================================================
# COLLABRYX BACKEND ENVIRONMENT CONFIGURATION
# =============================================================================
# DEVELOPMENT MODE - Docker Backend
# =============================================================================
# Usage: Copy to .env.local for local development with Docker Python worker
# Command: npm run docker:up (starts Python worker on port 8000)
# =============================================================================

# -----------------------------------------------------------------------------
# BACKEND MODE CONFIGURATION
# -----------------------------------------------------------------------------
# Mode options:
# - 'auto': Auto-detect (try Docker, fallback to Edge)
# - 'docker': Force Docker backend (local development)
# - 'render': Force Render backend (testing prod config locally)
# - 'edge-only': Skip backend, use Edge Function only
BACKEND_MODE=docker

# Local Docker backend URL (Python worker)
BACKEND_URL_DOCKER=http://localhost:8000

# Render backend URL (not used in dev, but keep for reference)
BACKEND_URL_RENDER=https://collabryx-backend.onrender.com

# Fallback strategy when backend unavailable
BACKEND_FALLBACK=edge

# -----------------------------------------------------------------------------
# SUPABASE CONFIGURATION
# -----------------------------------------------------------------------------
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://supabase.ahsanali.cc
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# -----------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
DEVELOPMENT_MODE=true
DEBUG=true

# -----------------------------------------------------------------------------
# PYTHON WORKER CONFIGURATION (Docker)
# -----------------------------------------------------------------------------
# This is used by the Next.js API routes to communicate with Docker
PYTHON_WORKER_URL=http://localhost:8000
PYTHON_WORKER_PORT=8000

# -----------------------------------------------------------------------------
# EXTERNAL API KEYS (Optional - services have fallbacks)
# -----------------------------------------------------------------------------
# Google Perspective API - Content moderation (https://developers.perspectiveapi.com/)
# Leave empty to use keyword-based toxicity detection fallback
PERSPECTIVE_API_KEY=

# Google Gemini API - AI Mentor (https://makersuite.google.com/app/apikey)
# Leave empty to use predefined response fallback
GEMINI_API_KEY=

# Hugging Face Token - Spam detection (optional, uses rule-based fallback)
HUGGING_FACE_TOKEN=

# Allowed CORS origins for the Python worker
ALLOWED_ORIGINS=http://localhost:3000,https://collabryx.vercel.app

# -----------------------------------------------------------------------------
# AI/EMBEDDING CONFIGURATION
# -----------------------------------------------------------------------------
# Hugging Face API key (used by Edge Function fallback)
HF_API_KEY=hf_rrxzvDVLndahRAkMshQovIqTncMXLmtgp

# AI Mentor provider configuration
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-placeholder-add-your-key
# ANTHROPIC_API_KEY=sk-ant-placeholder-add-your-key

# -----------------------------------------------------------------------------
# SECURITY CONFIGURATION
# -----------------------------------------------------------------------------
# CSRF secret (generate with: openssl rand -hex 32)
CSRF_SECRET=your-csrf-secret-generate-with-openssl-rand-hex-32

# Session cookie settings
SESSION_COOKIE_NAME=collabryx-session
SESSION_COOKIE_MAX_AGE=604800

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Strict rate limiting for sensitive endpoints
RATE_LIMIT_STRICT_WINDOW_MS=60000
RATE_LIMIT_STRICT_MAX_REQUESTS=10

# -----------------------------------------------------------------------------
# LOGGING & MONITORING
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
ENABLE_LOGGING=true
ENABLE_PERFORMANCE_LOGS=true

# -----------------------------------------------------------------------------
# SENTRY - Error Tracking (Optional in Dev)
# -----------------------------------------------------------------------------
# Leave empty to disable in development
# Get from: https://sentry.io/settings/your-org/projects/
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# -----------------------------------------------------------------------------
# POSTHOG - Analytics (Optional in Dev)
# -----------------------------------------------------------------------------
# Leave empty to disable in development
# Get from: https://app.posthog.com/settings/project-keys
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_AI_FEATURES=true
NEXT_PUBLIC_ENABLE_BETA_FEATURES=true
NEXT_PUBLIC_ENABLE_REALTIME=true

# -----------------------------------------------------------------------------
# CACHE CONFIGURATION
# -----------------------------------------------------------------------------
# React Query cache settings (milliseconds)
REACT_QUERY_STALE_TIME=120000
REACT_QUERY_GC_TIME=600000

# Dashboard cache TTL (seconds)
DASHBOARD_CACHE_TTL=300

# -----------------------------------------------------------------------------
# FILE UPLOAD CONFIGURATION
# -----------------------------------------------------------------------------
# Maximum file size in bytes (50MB)
MAX_FILE_SIZE=52428800

# Allowed MIME types for uploads
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp
ALLOWED_VIDEO_TYPES=video/mp4,video/webm,video/quicktime

# -----------------------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------------------
# 1. Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# 2. Other variables are only available on the server
# 3. Changes to .env.local require restarting the dev server
# 4. NEVER commit .env.local to version control!
# 
# Docker Commands:
# - Start: npm run docker:up
# - Stop: npm run docker:down
# - Logs: docker-compose logs -f
# - Health: curl http://localhost:8000/health
# =============================================================================
