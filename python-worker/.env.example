# Collabryx Python Worker - Environment Variables Template
# Copy this file to .env and fill in your values

# =====================================================
# REQUIRED VARIABLES
# =====================================================

# Supabase Project URL
# Format: https://<project-id>.supabase.co
SUPABASE_URL=

# Supabase Service Role Key (keep secret!)
# Found in Supabase Dashboard > Settings > API
SUPABASE_SERVICE_ROLE_KEY=

# =====================================================
# OPTIONAL VARIABLES
# =====================================================

# Allowed CORS Origins (comma-separated)
# Default: http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Google Perspective API Key (for content moderation)
# Get from: https://developers.perspectiveapi.com/
PERSPECTIVE_API_KEY=

# Google Gemini API Key (for AI mentor)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# Hugging Face Token (for ML models)
# Get from: https://huggingface.co/settings/tokens
HUGGING_FACE_TOKEN=

# =====================================================
# DEVELOPMENT VARIABLES
# =====================================================

# Python debug mode (set to 1 for verbose logging)
PYTHONDEBUG=0

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
