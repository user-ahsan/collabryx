# Collabryx .dockerignore
# Minimizes Docker build context for faster builds and smaller images.

# ===========================================
# Version Control
# ===========================================
.git
.gitignore
.gitattributes

# ===========================================
# Dependencies (installed during build)
# ===========================================
node_modules
bower_components

# ===========================================
# Environment Files (secrets - never in images)
# ===========================================
.env
.env.local
.env.production
.env.staging
.env.development
!.env.example

# ===========================================
# Build Outputs
# ===========================================
.next
out
dist
build
*.tsbuildinfo

# ===========================================
# Temporary & Cache Files
# ===========================================
.tmp
.temp
.cache
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===========================================
# Test Files (not needed in production image)
# ===========================================
tests
test
__tests__
coverage
.nyc_output
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx

# ===========================================
# AI Agent & Config Directories
# ===========================================
.claude
.agents
.opencode

# ===========================================
# IDE & Editor Files
# ===========================================
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ===========================================
# Documentation (not needed in runtime image)
# ===========================================
docs
*.md
!README.md

# ===========================================
# Docker Files (self-reference)
# ===========================================
docker-compose*.yml
Dockerfile*
.dockerignore

# ===========================================
# Python Worker (excluded from Next.js build context)
# ===========================================
python-worker

# ===========================================
# Supabase (migrations run separately)
# ===========================================
supabase
