# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# bun
bun.lock

# python worker
python-worker/.venv/
python-worker/__pycache__/
python-worker/*.pyc
python-worker/*.pyo
python-worker/.pytest_cache/
.ruff_cache/

# supabase local dev
supabase/.branches
supabase/.temp
supabase/.env.keys
supabase/.env.local
supabase/.env.*.local

# supabase credentials (sensitive)
supabase-credentials.md

# typescript
*.tsbuildinfo
next-env.d.ts

# seed data python cache
scripts/seed-data/__pycache__/
scripts/seed-data/data_generators/__pycache__/
scripts/seed-data/seeders/__pycache__/
scripts/seed-data/*.pyc
scripts/seed-data/*.pyo
scripts/seed-data/.venv/

