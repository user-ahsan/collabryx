{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  
  "framework": "nextjs",
  
  "regions": ["iad1"],
  
  "functions": {
    "maxDuration": 60,
    "memory": 1024
  },
  
  "buildCommand": "npm run build",
  "devCommand": "npm run dev:skip-docker",
  "installCommand": "npm install",
  
  "outputDirectory": ".next",
  
  "env": {
    "NODE_ENV": "production"
  },
  
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  
  "crons": [
    {
      "path": "/api/notifications/cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/analytics/daily",
      "schedule": "0 4 * * *"
    }
  ]
}
