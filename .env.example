# =============================================================================
# COLLABRYX ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE (Required)
# -----------------------------------------------------------------------------
# Get these from: https://app.supabase.com/project/_/settings/api

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public anonymous key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (KEEP SECRET! Server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------

# Application URL (used for redirects, OAuth, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development



# -----------------------------------------------------------------------------
# FEATURE FLAGS (Optional)
# -----------------------------------------------------------------------------

# Enable AI features
# NEXT_PUBLIC_ENABLE_AI_FEATURES=true

# Enable beta features
# NEXT_PUBLIC_ENABLE_BETA_FEATURES=false

# Maintenance mode
# NEXT_PUBLIC_MAINTENANCE_MODE=false

# -----------------------------------------------------------------------------
# PYTHON WORKER (Required for Embeddings & ML Services)
# -----------------------------------------------------------------------------

# Python Worker URL (for embedding generation and ML services)
PYTHON_WORKER_URL=http://localhost:8000
PYTHON_WORKER_PORT=8000

# -----------------------------------------------------------------------------
# EXTERNAL API KEYS (Optional - services have fallbacks)
# -----------------------------------------------------------------------------

# Google Gemini API - AI Mentor
# Get from: https://makersuite.google.com/app/apikey
# Leave empty to use predefined response fallback
GEMINI_API_KEY=

# AI Providers (for AI features)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# DEVELOPMENT (Optional)
# -----------------------------------------------------------------------------

# Enable debug mode (shows detailed logs)
DEBUG=false
DEVELOPMENT_MODE=true

# Skip email verification in development
SKIP_EMAIL_VERIFICATION=true

# -----------------------------------------------------------------------------
# SECURITY (Optional)
# -----------------------------------------------------------------------------

# Enable security features
NEXT_PUBLIC_ENABLE_SECURITY=true

# =============================================================================
# NOTES
# =============================================================================
# 
# 1. Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# 2. Other variables are only available on the server
# 3. Changes to .env.local require restarting the dev server
# 4. For production, set these in your hosting platform's environment settings
# 
# =============================================================================
