# =============================================================================
# COLLABRYX — COMPLETE ENVIRONMENT VARIABLES REFERENCE
# =============================================================================
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to version control!
#
# Quick reference of ALL available options:
#   Required (4):  SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY, APP_URL
#   Recommended:   PYTHON_WORKER_URL, AI provider keys
#   Optional:      Feature flags, seeding limits, backend mode, debug flags
# =============================================================================

# =============================================================================
# 1. SUPABASE — Required
#    Get these from: https://app.supabase.com/project/_/settings/api
# =============================================================================

# Your Supabase project URL (e.g., https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public anonymous key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — KEEP SECRET! Server-side only. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# 2. APPLICATION — Required
# =============================================================================

# Application URL used for redirects, OAuth callbacks, CORS, etc.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment: development | production 
NODE_ENV=development
# Skip email verification (works server + client, NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SKIP_EMAIL_VERIFICATION=true


# Set to "true" when running inside a Docker container (auto-detected)
# IN_DOCKER_CONTAINER=false

# Set by Vercel automatically in production — do NOT set manually
# VERCEL=1

# =============================================================================
# 3. PYTHON WORKER — Required for embeddings, match generation, AI mentor, etc.
#    Docker:  docker compose up -d    (from python-worker/ directory)
#    Manual:  cd python-worker && uvicorn main:app --port 8000
# =============================================================================

# Python Worker URL for embedding generation and ML services
PYTHON_WORKER_URL=http://localhost:8000

# Worker port (used by Docker Compose and health checks)
PYTHON_WORKER_PORT=8000

# Public worker URL (if different from internal URL, e.g., Vercel → Render)
# NEXT_PUBLIC_WORKER_API_URL=https://your-worker.onrender.com

# =============================================================================
# 4. BACKEND ROUTING — Controls how Next.js connects to the Python worker
# =============================================================================

# Backend mode: auto | docker | render
#   auto   — Auto-detect: try Docker first, fallback to render
#   docker — Always use local Docker backend  (http://localhost:8000)
#   render — Always use Render cloud backend (requires BACKEND_URL_RENDER)
BACKEND_MODE=auto

# Render deployment URL for the Python worker (used when BACKEND_MODE=render or on Vercel)
# BACKEND_URL_RENDER=https://collabryx-worker.onrender.com

# Docker backend URL override (default: http://localhost:8000)
# BACKEND_URL_DOCKER=http://localhost:8000

# =============================================================================
# 5. AI PROVIDERS — Optional. Services gracefully degrade without keys.
# =============================================================================

# --- Legacy single-provider keys (backward compatible) ---

# OpenAI — for embeddings, AI mentor, content moderation
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Anthropic Claude — native API integration
# Get from: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...

# MiniMax — alternative AI provider
# MINIMAX_API_KEY=your-minimax-key-here
# MINIMAX_BASE_URL=https://api.minimax.chat/v1
# MINIMAX_MODEL=MiniMax-M2.7

# Google Gemini — AI Mentor fallback
# Get from: https://makersuite.google.com/app/apikey
# GEMINI_API_KEY=

# --- Multi-provider configuration (recommended — supports failover) ---
# Pattern: AI_PROVIDER_N_* where N = priority (1 = first choice, 2 = fallback, etc.)
# Each provider needs: NAME, API_KEY, BASE_URL, MODEL
# Optional per-provider: MAX_TOKENS, TEMPERATURE, TIMEOUT, PRIORITY
#
# Supported NAME values: openai, anthropic, groq, together, ollama, minimax
# Any OpenAI-compatible API works with NAME=openai + custom BASE_URL

# Provider 1: OpenAI (priority 1 — first choice)
# AI_PROVIDER_1_NAME=openai
# AI_PROVIDER_1_API_KEY=sk-...
# AI_PROVIDER_1_BASE_URL=https://api.openai.com/v1
# AI_PROVIDER_1_MODEL=gpt-4o-mini
# AI_PROVIDER_1_MAX_TOKENS=4096
# AI_PROVIDER_1_TEMPERATURE=0.7
# AI_PROVIDER_1_TIMEOUT=60000
# AI_PROVIDER_1_PRIORITY=1

# Provider 2: Groq (OpenAI-compatible, priority 2)
# AI_PROVIDER_2_NAME=groq
# AI_PROVIDER_2_API_KEY=gsk_...
# AI_PROVIDER_2_BASE_URL=https://api.groq.com/openai/v1
# AI_PROVIDER_2_MODEL=llama-3.3-70b-versatile

# Provider 3: Together AI (OpenAI-compatible, priority 3)
# AI_PROVIDER_3_NAME=together
# AI_PROVIDER_3_API_KEY=your-together-key
# AI_PROVIDER_3_BASE_URL=https://api.together.xyz/v1
# AI_PROVIDER_3_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# Provider 4: Ollama — self-hosted, no API key needed
# AI_PROVIDER_4_NAME=ollama
# AI_PROVIDER_4_API_KEY=           # Not required for local Ollama
# AI_PROVIDER_4_BASE_URL=http://localhost:11434/v1
# AI_PROVIDER_4_MODEL=llama3.1

# Provider 5: Anthropic Claude (native API, priority 5)
# AI_PROVIDER_5_NAME=anthropic
# AI_PROVIDER_5_API_KEY=sk-ant-...
# AI_PROVIDER_5_BASE_URL=https://api.anthropic.com
# AI_PROVIDER_5_MODEL=claude-sonnet-4-20250514

# --- OpenRouter — Primary Provider for Collabryx ---
# OpenRouter gives access to 300+ models (DeepSeek, OpenAI, Anthropic, Google, etc.)
# through a single OpenAI-compatible API. It is the recommended primary provider.
#
# Get an API key: https://openrouter.ai/settings/keys
# Browse models:  https://openrouter.ai/models
#
# Two ways to configure:
#
# Option A: Legacy shortcut (simple — set these 3 vars)
#   OPENROUTER_API_KEY=sk-or-v1-your-key-here
#   OPENROUTER_BASE_URL=https://openrouter.ai/api/v1       (optional, default shown)
#   OPENROUTER_MODEL=deepseek/deepseek-v4-flash            (optional, default shown)
#
# Option B: Multi-provider pattern (advanced — full control)
#   AI_PROVIDER_1_NAME=openrouter
#   AI_PROVIDER_1_API_KEY=sk-or-v1-your-key-here
#   AI_PROVIDER_1_BASE_URL=https://openrouter.ai/api/v1
#   AI_PROVIDER_1_MODEL=deepseek/deepseek-v4-flash
#   AI_PROVIDER_1_PRIORITY=1
#
# Available DeepSeek models through OpenRouter:
#   deepseek/deepseek-v4-flash         — V4 Flash (flagship, paid)
#   deepseek/deepseek-v4-flash:free    — V4 Flash (free tier, rate limited)
#   deepseek/deepseek-r1               — DeepSeek R1 (paid)
#   deepseek/deepseek-r1:free          — DeepSeek R1 (free)
#   deepseek/deepseek-chat-v3-0324    — DeepSeek V3 0324
#   deepseek/deepseek-chat:free       — DeepSeek V3 (free)
#
# Advanced env vars:
#   OPENROUTER_TITLE=Collabryx             — App name (shown on OpenRouter leaderboard)
#   OPENROUTER_REFERER=http://localhost:3000 — Your site URL
#   OPENROUTER_MAX_TOKENS=8192             — Max response tokens
#   OPENROUTER_TEMPERATURE=0.7             — Sampling temperature
#   OPENROUTER_TIMEOUT=120000              — Request timeout in ms

# =============================================================================
# 6. FEATURE FLAGS — Optional. All default to sensible values.
# =============================================================================

# Enable AI-powered features (mentor, content moderation, smart matching)
# NEXT_PUBLIC_ENABLE_AI_FEATURES=true

# Enable beta/experimental features
# NEXT_PUBLIC_ENABLE_BETA_FEATURES=false

# Put the app in maintenance mode (shows maintenance page to all users)
# NEXT_PUBLIC_MAINTENANCE_MODE=false

# Enable security features (CSRF protection, rate limiting, bot detection)
# NEXT_PUBLIC_ENABLE_SECURITY=true

# =============================================================================
# 7. DATABASE SEEDING — Control what and how much test data is created.
#    Run: python scripts/seed-data/main.py    (or: cd scripts/seed-data && python main.py)
# =============================================================================

# --- Seeding toggles (set to "false" to skip a module) ---
# SEED_PROFILES=true
# SEED_POSTS=true
# SEED_CONNECTIONS=true
# SEED_MATCHES=true
# SEED_CONVERSATIONS=true
# SEED_MESSAGES=true
# SEED_NOTIFICATIONS=true           # Legacy alias: ENABLE_NOTIFICATIONS
# SEED_MENTOR_SESSIONS=true         # Legacy alias: ENABLE_MENTOR_SESSIONS
# SEED_EMBEDDINGS=true              # Legacy alias: ENABLE_EMBEDDINGS

# --- Seeding behavior ---
# SEED_USER_PASSWORD=DemoPass123!   # Password for all seeded users
# INCREMENTAL_SEEDING=true          # Skip existing records instead of failing
# CHECK_DUPLICATES=true             # Check for duplicate emails before creating
# SEED_PROFILES_RANDOMIZE_INDUSTRIES=true  # Randomize industry assignments

# --- Seeding limits (use "-1" for unlimited, "10,50" for random range) ---
# LIMIT_PROFILES=100                # Max profiles to create
# LIMIT_POSTS=300                   # Max posts to create
# LIMIT_CONNECTIONS=500             # Max connections to create
# LIMIT_MATCHES_PER_USER=5          # Max match suggestions per user
# LIMIT_CONVERSATIONS=150           # Max conversations to create
# LIMIT_MESSAGES_PER_CONVERSATION=5,20    # Random range: 5-20 messages per conversation
# LIMIT_COMMENTS_PER_POST=3,8             # Random range: 3-8 comments per post
# LIMIT_REACTIONS_PER_POST=5,15           # Random range: 5-15 reactions per post
# LIMIT_NOTIFICATIONS_PER_USER=5    # Max notifications per user
# LIMIT_MENTOR_SESSIONS=50          # Max AI mentor sessions

# --- Legacy limit aliases (still work, but prefer LIMIT_* above) ---
# SEED_COUNT_PROFILES=100
# SEED_COUNT_POSTS=300
# SEED_COUNT_CONNECTIONS=500
# SEED_COUNT_CONVERSATIONS=150
# SEED_COUNT_MENTOR_SESSIONS=50

# --- Batch processing (avoid rate limiting the Supabase REST API) ---
# BATCH_SIZE=10                     # Records per batch before pausing
# DELAY_BETWEEN_BATCHES=2.0         # Seconds to pause between batches

# =============================================================================
# 8. DEVELOPMENT — Local dev convenience settings.
# =============================================================================

# NOTE: DEBUG, LOG_LEVEL, ENABLE_PERFORMANCE_LOGS, ENABLE_LOGGING are REMOVED.
# All debug/performance/dev-logging features are derived from NODE_ENV:
#   NODE_ENV=development → everything ON (verbose logs, perf timers, dev UI)
#   NODE_ENV=production  → everything OFF (zero overhead in production)
# This prevents accidental debug leaks and simplifies configuration.

# =============================================================================
# 9. SECURITY — Optional hardening flags.
# =============================================================================

# Note: CSRF tokens are auto-generated per-session. No env var needed.
# Rate limiting uses database-backed counters. No env var needed.
# Bot detection uses built-in heuristics. No env var needed.

# =============================================================================
# ENVIRONMENT VARIABLE REFERENCE SUMMARY
# =============================================================================
#
# REQUIRED (4):
#   NEXT_PUBLIC_SUPABASE_URL         Supabase project URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY    Public anonymous key
#   SUPABASE_SERVICE_ROLE_KEY        Service role key (server-only)
#   NEXT_PUBLIC_APP_URL              Application URL
#
# RECOMMENDED (1):
#   PYTHON_WORKER_URL                Embedding/ML worker URL
#
# AI (any one provider):
#   OPENROUTER_API_KEY               OpenRouter API key (legacy, primary)
#   OPENAI_API_KEY                   OpenAI API key (legacy fallback)
#   AI_PROVIDER_1_API_KEY + NAME     Multi-provider (recommended)
#
# SEEDING (optional overrides):
#   SEED_PROFILES, SEED_POSTS, etc.  Module toggles
#   LIMIT_PROFILES, LIMIT_POSTS...   Data volume limits
#   BATCH_SIZE, DELAY_BETWEEN_BATCHES  Rate limit controls
#
# BACKEND ROUTING:
#   BACKEND_MODE                     auto | docker | render
#   BACKEND_URL_RENDER               Render deployment URL
#   BACKEND_URL_DOCKER               Docker backend URL
#
# DEVELOPMENT:
#   NEXT_PUBLIC_SKIP_EMAIL_VERIFICATION  (all other dev features derive from NODE_ENV)
#
# FEATURE FLAGS:
#   NEXT_PUBLIC_ENABLE_AI_FEATURES, _BETA_FEATURES, _MAINTENANCE_MODE, _SECURITY
#
# PREFIX RULES:
#   NEXT_PUBLIC_*  → Exposed to browser (use only for non-sensitive values)
#   No prefix      → Server-side only (safe for secrets)
#
# CHANGES REQUIRE RESTART of `npm run dev`.
# For production, set these in your hosting platform (Vercel/Render/Railway).
# =============================================================================
