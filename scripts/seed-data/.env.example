# Collabryx Seed Data Configuration
# Copy this file to .env and fill in your values

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Python Worker Configuration (for real embeddings)
PYTHON_WORKER_URL=http://localhost:8000

# Seed Configuration
SEED_COUNT_PROFILES=100
SEED_COUNT_POSTS=300
SEED_COUNT_CONNECTIONS=500
SEED_COUNT_CONVERSATIONS=150
SEED_COUNT_MESSAGES=1000
SEED_COUNT_NOTIFICATIONS=500
SEED_COUNT_MENTOR_SESSIONS=50

# Features to enable
ENABLE_EMBEDDINGS=true
ENABLE_MENTOR_SESSIONS=true
ENABLE_NOTIFICATIONS=true

# Batch processing
BATCH_SIZE=10
DELAY_BETWEEN_BATCHES=2.0

# Industry focus (comma-separated, 20 industries)
INDUSTRIES=Fintech,EdTech,HealthTech,E-commerce,AI/ML,Cybersecurity,Blockchain,Cloud Computing,DevTools,SaaS,Gaming,Social Media,PropTech,AgriTech,CleanTech,Biotech,Robotics,IoT,AR/VR,Data Analytics
