# =============================================================================
# COLLABRYX DATABASE SEEDER - CONFIGURATION
# =============================================================================
# Copy this file to .env and configure your seeding options
# =============================================================================

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
SUPABASE_URL=https://supabase.ahsanali.cc
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# PYTHON WORKER (for embeddings)
# =============================================================================
PYTHON_WORKER_URL=http://localhost:8000

# =============================================================================
# SEEDING TOGGLES (true/false) - Set to false to skip specific seeders
# =============================================================================
SEED_PROFILES=true
SEED_POSTS=true
SEED_CONNECTIONS=true
SEED_MATCHES=true
SEED_CONVERSATIONS=true
SEED_MESSAGES=true
SEED_NOTIFICATIONS=true
SEED_MENTOR_SESSIONS=true
SEED_EMBEDDINGS=true

# =============================================================================
# SEED LIMITS
# Set to 0 to skip, -1 to seed based on existing data (e.g., 10 messages per conversation)
# =============================================================================

# Profiles: Number of user profiles to create
LIMIT_PROFILES=100

# Posts: Total number of posts to create
LIMIT_POSTS=300

# Comments: Number of comments per post (format: min,max or single number)
LIMIT_COMMENTS_PER_POST=3,8

# Reactions: Number of reactions per post (format: min,max)
LIMIT_REACTIONS_PER_POST=5,15

# Connections: Total number of connection requests
LIMIT_CONNECTIONS=500

# Matches: Match suggestions per user
LIMIT_MATCHES_PER_USER=5

# Conversations: Total number of conversation threads
LIMIT_CONVERSATIONS=150

# Messages: Messages per conversation (format: min,max)
LIMIT_MESSAGES_PER_CONVERSATION=5,20

# Notifications: Notifications per user
LIMIT_NOTIFICATIONS_PER_USER=5

# Mentor Sessions: Total AI mentor sessions
LIMIT_MENTOR_SESSIONS=50

# =============================================================================
# BATCH PROCESSING & RATE LIMITING
# =============================================================================
BATCH_SIZE=10
DELAY_BETWEEN_BATCHES=2.0

# =============================================================================
# DATA DIVERSITY
# =============================================================================
INDUSTRIES=Fintech,EdTech,HealthTech,E-commerce,AI/ML,Cybersecurity,Blockchain,Cloud Computing,DevTools,SaaS,Gaming,Social Media,PropTech,AgriTech,CleanTech,Biotech,Robotics,IoT,AR/VR,Data Analytics

# =============================================================================
# USER CREDENTIALS (for seeded accounts)
# =============================================================================
DEFAULT_PASSWORD=DemoPass123!
